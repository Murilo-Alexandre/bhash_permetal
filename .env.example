# ==========================================
# BHASH - configuração central do projeto
# ==========================================
# Copie para ".env" na raiz do repositório e ajuste os valores.

# Banco / Backend
DATABASE_URL=postgresql://bhash:bhashpass@localhost:5432/bhash
JWT_SECRET=troque-por-uma-chave-forte
# Em servidor interno com proxy HTTPS, use os domínios internos:
# CORS_ORIGINS=https://chat.interno.empresa,https://admin-chat.interno.empresa
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,LAN
APP_HOST=0.0.0.0
PORT=3000

# Frontends (opcional):
# - dev local sem proxy: http://localhost:3000
# - deploy interno com reverse proxy HTTPS: /api
VITE_API_BASE=http://localhost:3000
VITE_WS_PATH=/socket.io

# Desktop Electron (defaults embutidos no instalador)
CHAT_WEB_URL=http://localhost:5173
DESKTOP_UPDATE_URL=https://updates.bhash.com/desktop/win
# Opcional: pasta local/rede onde o script de release publica os artefatos
# Exemplo Windows share: \\\\srv-arquivos\\updates\\bhash\\desktop\\win
DESKTOP_UPDATE_PUBLISH_DIR=

# Seed de contas (opcional)
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=ChangeMeNow!123456
SEED_SUPERADMIN_NAME=SuperAdmin

SEED_ADMIN_USERNAME=adminteste
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrador Teste

SEED_USER1_USERNAME=userteste1
SEED_USER1_PASSWORD=userteste1
SEED_USER1_NAME=Usuario Teste 1

SEED_USER2_USERNAME=userteste2
SEED_USER2_PASSWORD=userteste2
SEED_USER2_NAME=Usuario Teste 2

SEED_PRIMARY_COLOR=#001F3F
SEED_LOGO_URL=
