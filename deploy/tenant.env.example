# ===============================================
# BHASH - tenant config (fonte unica por empresa)
# ===============================================
# Copie para deploy/tenant.env e ajuste os valores.

# Identificacao
TENANT_SLUG=empresa-demo
COMPANY_NAME=Empresa Demo

# Rede interna
SERVER_IP=192.168.1.10
CHAT_HOST=chat.empresa.local
# Admin HTTPS e opcional. Se desativado, admin fica interno em http://SERVER_IP:5174
ADMIN_HTTPS_ENABLED=false
ADMIN_HOST=
# ADMIN_URL=http://192.168.1.10:5174
UPDATES_HOST=updates.empresa.local
UPDATES_PATH_PREFIX=/desktop/win

# Canal de update desktop (pasta local no servidor que o Caddy vai servir)
UPDATES_PUBLISH_DIR=C:\caddy\updates\desktop\win

# Backend / Banco
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bhash
DB_USER=bhash
DB_PASSWORD=troque-essa-senha
JWT_SECRET=troque-por-uma-chave-forte

# Front/backend runtime
APP_HOST=0.0.0.0
PORT=3000
VITE_WS_PATH=/socket.io

# Seed inicial (opcional)
SEED_SUPERADMIN_USERNAME=superadmin
SEED_SUPERADMIN_PASSWORD=ChangeMeNow!123456
SEED_SUPERADMIN_NAME=SuperAdmin
SEED_ADMIN_USERNAME=adminteste
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Administrador Teste

# Tema (opcional)
SEED_PRIMARY_COLOR=#001F3F
SEED_LOGO_URL=

# Nginx template (opcional, Linux)
NGINX_CHAT_CERT_PATH=/etc/ssl/certs/chat.empresa.local.crt
NGINX_CHAT_CERT_KEY_PATH=/etc/ssl/private/chat.empresa.local.key
# Usado apenas se ADMIN_HTTPS_ENABLED=true
NGINX_ADMIN_CERT_PATH=/etc/ssl/certs/admin-chat.empresa.local.crt
NGINX_ADMIN_CERT_KEY_PATH=/etc/ssl/private/admin-chat.empresa.local.key
