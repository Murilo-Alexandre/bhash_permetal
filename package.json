{
  "name": "bhash-workspace",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "env:init": "node scripts/env/init-root-env.cjs",
    "dev:all": "npm run env:init && concurrently -k -n backend,frontend,admin -c green,cyan,magenta \"npm --prefix backend run start:dev\" \"npm --prefix frontend run dev\" \"npm --prefix frontend-admin run dev\"",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:status": "docker compose ps",
    "infra:logs": "docker compose logs -f --tail=200",
    "install:all": "npm install && npm --prefix backend install && npm --prefix frontend install && npm --prefix frontend-admin install",
    "build:all": "npm --prefix backend run build && npm --prefix frontend run build && npm --prefix frontend-admin run build",
    "prisma:generate": "npm --prefix backend run prisma:generate",
    "prisma:migrate:deploy": "npm --prefix backend run prisma:migrate:deploy",
    "setup:server": "npm run env:init && npm run install:all && npm run prisma:generate && npm run prisma:migrate:deploy && npm run build:all",
    "services:start": "pm2 start ecosystem.config.cjs --update-env",
    "services:start:proxy": "pm2 start ecosystem.proxy.config.cjs --update-env",
    "services:reload": "pm2 reload ecosystem.config.cjs --update-env",
    "services:reload:proxy": "pm2 reload ecosystem.proxy.config.cjs --update-env",
    "services:restart": "pm2 restart ecosystem.config.cjs --update-env",
    "services:restart:proxy": "pm2 restart ecosystem.proxy.config.cjs --update-env",
    "services:stop": "pm2 stop ecosystem.config.cjs",
    "services:stop:proxy": "pm2 stop ecosystem.proxy.config.cjs",
    "services:delete": "pm2 delete ecosystem.config.cjs",
    "services:delete:proxy": "pm2 delete ecosystem.proxy.config.cjs",
    "services:status": "pm2 status",
    "services:logs": "pm2 logs --lines 200",
    "services:save": "pm2 save",
    "services:resurrect": "pm2 resurrect",
    "server:deploy": "npm run setup:server && npm run services:start && npm run services:save",
    "server:update": "npm run build:all && npm run services:reload && npm run services:save",
    "desktop:install": "npm --prefix desktop-electron install",
    "desktop:dev": "npm run env:init && npm --prefix desktop-electron run dev",
    "desktop:start": "npm run env:init && npm --prefix desktop-electron run start",
    "desktop:dist": "npm run env:init && npm --prefix desktop-electron run dist",
    "desktop:dist:win": "npm run env:init && npm --prefix desktop-electron run dist:win",
    "desktop:release:win": "node scripts/desktop/release-win.cjs --bump patch",
    "desktop:release:win:minor": "node scripts/desktop/release-win.cjs --bump minor",
    "desktop:release:win:major": "node scripts/desktop/release-win.cjs --bump major",
    "desktop:updater:install": "powershell -ExecutionPolicy Bypass -File .\\scripts\\windows\\install-desktop-updater-task.ps1",
    "desktop:updater:install:insecure": "powershell -ExecutionPolicy Bypass -File .\\scripts\\windows\\install-desktop-updater-task.ps1 -AllowInsecureTls",
    "desktop:updater:remove": "powershell -ExecutionPolicy Bypass -File .\\scripts\\windows\\remove-desktop-updater-task.ps1",
    "desktop:updater:status": "powershell -ExecutionPolicy Bypass -File .\\scripts\\windows\\status-desktop-updater-task.ps1",
    "deploy:init": "node scripts/deploy/init-tenant-env.cjs",
    "deploy:render": "node scripts/deploy/render-tenant.cjs",
    "deploy:render:apply": "node scripts/deploy/render-tenant.cjs --apply-root-env",
    "deploy:render:publish-tools": "node scripts/deploy/render-tenant.cjs --publish-tools",
    "deploy:server:up": "node scripts/deploy/server-up.cjs",
    "deploy:desktop:release": "node scripts/deploy/release-desktop-tenant.cjs --bump patch",
    "deploy:desktop:release:minor": "node scripts/deploy/release-desktop-tenant.cjs --bump minor",
    "deploy:desktop:release:major": "node scripts/deploy/release-desktop-tenant.cjs --bump major",
    "deploy:desktop:publish-tools": "node scripts/deploy/release-desktop-tenant.cjs --publish-tools-only"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "pm2": "^6.0.13"
  }
}
