generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum MessageContentType {
  TEXT
  IMAGE
  FILE
}

enum MediaRetentionInterval {
  DAILY
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  YEARLY
}

model Company {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users User[]

  @@map("companies")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())

  users User[]

  @@map("departments")
}

model User {
  id                 String   @id @default(uuid())
  username           String   @unique
  name               String

  email              String?
  extension          String?
  avatarUrl          String?

  passwordHash       String
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  lastLoginAt        DateTime?

  companyId          String?
  departmentId       String?

  company            Company?    @relation(fields: [companyId], references: [id])
  department         Department? @relation(fields: [departmentId], references: [id])

  conversationsA     Conversation[]   @relation("ConversationUserA")
  conversationsB     Conversation[]   @relation("ConversationUserB")
  sentMessages       Message[]        @relation("MessageSender")
  conversationStates ConversationUserState[]
  messageVisibility  MessageVisibility[]
  favoriteMessages   MessageFavorite[]
  reactions          MessageReaction[]

  @@index([companyId])
  @@index([departmentId])

  @@map("users")
}

model AdminAccount {
  id                    String   @id @default(uuid())
  username              String   @unique
  name                  String
  passwordHash          String
  isActive              Boolean  @default(true)
  isSuperAdmin          Boolean  @default(false)
  mustChangeCredentials Boolean  @default(false)
  mustChangePassword    Boolean  @default(false)
  createdAt             DateTime @default(now())
  lastLoginAt           DateTime?

  @@map("admin_accounts")
}

model AppConfig {
  id                      String                 @id
  primaryColor            String                 @default("#001F3F")
  primaryTextColor        String                 @default("#F0F0F0")
  logoUrl                 String?
  mediaRetentionEnabled   Boolean                @default(false)
  mediaRetentionInterval  MediaRetentionInterval @default(MONTHLY)
  mediaRetentionIntervalCount Int                @default(1)
  mediaRetentionRunHour   Int                    @default(0)
  mediaRetentionRunMinute Int                    @default(0)
  mediaRetentionShowToUsers Boolean              @default(false)
  mediaRetentionNextRunAt DateTime?
  mediaRetentionLastRunAt DateTime?
  mediaRetentionLastMediaCount Int               @default(0)
  mediaRetentionLastFileCount Int                @default(0)
  mediaRetentionLastSummary String?

  @@map("app_config")
}

model Conversation {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userAId   String
  userBId   String

  userA     User @relation("ConversationUserA", fields: [userAId], references: [id])
  userB     User @relation("ConversationUserB", fields: [userBId], references: [id])

  messages  Message[]
  states    ConversationUserState[]

  @@unique([userAId, userBId])
  @@index([updatedAt])
  @@map("conversations")
}

model Message {
  id             String             @id @default(uuid())
  createdAt      DateTime           @default(now())

  conversationId String
  senderId       String

  body           String?
  contentType    MessageContentType @default(TEXT)

  attachmentUrl  String?
  attachmentName String?
  attachmentMime String?
  attachmentSize Int?

  replyToId      String?
  deletedAt      DateTime?

  conversation   Conversation       @relation(fields: [conversationId], references: [id])
  sender         User               @relation("MessageSender", fields: [senderId], references: [id])

  replyTo        Message?           @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]          @relation("MessageReply")

  favorites      MessageFavorite[]
  reactions      MessageReaction[]
  hiddenForUsers MessageVisibility[]

  @@index([conversationId, createdAt])
  @@index([replyToId])
  @@index([senderId])
  @@map("messages")
}

model ConversationUserState {
  id             String   @id @default(uuid())
  conversationId String
  userId         String
  hidden         Boolean  @default(false)
  pinned         Boolean  @default(false)
  clearedAt      DateTime?
  lastReadAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, hidden])
  @@index([userId, pinned])
  @@map("conversation_user_states")
}

model MessageVisibility {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  hiddenAt  DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId, hiddenAt])
  @@map("message_visibility")
}

model MessageFavorite {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_favorites")
}

model MessageReaction {
  id        String   @id @default(uuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([userId])
  @@map("message_reactions")
}
